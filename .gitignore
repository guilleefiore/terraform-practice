# Terraform local directory
.terraform/
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform variable files that may contain sensitive data
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
plan.out

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config files
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/